<%- include('../../partials/layout-start', { title, nav }) %>
<section class="section">
  <div class="section-title">
    <h2>Medical records</h2>
    <p class="muted">Diagnoses, prescriptions, lab files, and imaging.</p>
  </div>
  <div class="card">
    <h3>Upload a file</h3>
    <form class="form">
      <label>File<input type="file" /></label>
      <label>Type<select><option>Lab result</option><option>Imaging</option><option>Prescription</option></select></label>
      <label>Doctor comments<textarea rows="3" placeholder="Optional notes"></textarea></label>
      <button class="primary" type="submit">Upload</button>
    </form>
  </div>
  <div class="grid two">
    <div class="card">
      <h4>May 12 2026</h4>
      <p class="muted">Dr Ahmed Benali · Hypertension</p>
      <p>Prescription: Amlodipine</p>
      <p class="muted">Download: lab-results.pdf</p>
    </div>
  </div>
</section>
<%- include('../../partials/layout-end') %>
