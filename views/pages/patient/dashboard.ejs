<%- include('../../partials/layout-start', { title, nav }) %>
<section class="section">
  <div class="section-title">
    <h2>Dashboard</h2>
    <p class="muted">Upcoming appointments, notifications, and quick actions.</p>
  </div>
  <div class="grid two">
    <div class="card">
      <h3>Upcoming appointments</h3>
      <p class="muted">No appointments yet.</p>
    </div>
    <div class="card">
      <h3>Notifications</h3>
      <ul style="color:var(--muted); display:grid; gap:6px;">
        <li>Accepted appointment</li>
        <li>New medication</li>
        <li>New lab result</li>
      </ul>
    </div>
  </div>
</section>
<%- include('../../partials/layout-end') %>
