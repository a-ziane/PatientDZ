<%- include('../partials/layout-start', { title, nav }) %>
<section class="section">
  <div class="section-title">
    <h2>Create account</h2>
    <p class="muted">Patients and doctors can register with phone + password.</p>
  </div>
  <div class="card" style="max-width:520px;">
    <form class="form" method="POST" action="/auth/signup">
      <label>Full name
        <input name="name" type="text" placeholder="Full name" required />
      </label>
      <label>Phone number
        <input name="phone" type="text" placeholder="+213 5xx xxx xxx" required />
      </label>
      <label>Password
        <input name="password" type="password" placeholder="Create a password" required />
      </label>
      <label>Account type
        <select name="role" required>
          <option value="patient">Patient</option>
          <option value="doctor">Doctor</option>
        </select>
      </label>
      <button class="primary" type="submit">Create account</button>
    </form>
  </div>
</section>
<%- include('../partials/layout-end') %>
