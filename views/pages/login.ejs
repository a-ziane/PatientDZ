<%- include('../partials/layout-start', { title, nav }) %>
<section class="section">
  <div class="section-title">
    <h2><%= role === 'doctor' ? 'Doctor sign in' : 'Patient sign in' %></h2>
    <p class="muted">Phone + password (Supabase Auth).</p>
  </div>
  <div class="card" style="max-width:520px;">
    <form class="form" method="POST" action="<%= action %>">
      <label>Phone number
        <input name="phone" type="text" placeholder="+213 5xx xxx xxx" required />
      </label>
      <label>Password
        <input name="password" type="password" placeholder="••••••••" required />
      </label>
      <button class="primary" type="submit">Sign in</button>
    </form>
    <% if (typeof error !== 'undefined' && error) { %>
      <p style="color:#dc2626; margin-top:10px;"><%= error %></p>
    <% } %>
  </div>
</section>
<%- include('../partials/layout-end') %>
